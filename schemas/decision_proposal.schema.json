{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "proposal_id",
    "basis_date",
    "as_of",
    "generated_at",
    "recommended_action",
    "requires_human_review",
    "confidence",
    "review_state",
    "decision_preview",
    "gate_summary",
    "explanation",
    "invalidation_conditions",
    "source_ids"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "status": { "type": "string", "enum": ["ok", "empty"] },
    "proposal_id": { "type": "string", "minLength": 1 },
    "basis_date": { "type": ["string", "null"], "format": "date" },
    "as_of": { "type": ["string", "null"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "recommended_action": {
      "type": "string",
      "enum": ["observe", "research_first", "rebalance_candidate", "no_action"]
    },
    "requires_human_review": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "review_state": { "type": "string", "enum": ["ready", "review_required", "blocked", "empty"] },
    "decision_preview": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "proposal", "current_weight", "target_weight", "delta_weight_pp", "rationale", "gates"],
        "properties": {
          "symbol": { "type": "string" },
          "proposal": { "type": "string", "enum": ["observe", "research_first", "rebalance_candidate", "no_action"] },
          "current_weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "target_weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "delta_weight_pp": { "type": "number", "minimum": -100, "maximum": 100 },
          "rationale": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "gates": {
            "type": "object",
            "additionalProperties": false,
            "required": ["profile", "valuation", "liquidity", "research_first", "risk_boundary"],
            "properties": {
              "profile": { "type": "string", "enum": ["pass", "fail", "blocked", "unknown"] },
              "valuation": { "type": "string", "enum": ["pass", "fail", "blocked", "unknown"] },
              "liquidity": { "type": "string", "enum": ["pass", "fail", "blocked", "unknown"] },
              "research_first": { "type": "boolean" },
              "risk_boundary": { "type": "string", "enum": ["pass", "warn", "block", "missing"] }
            }
          }
        }
      }
    },
    "gate_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["research_first", "risk_boundary", "macro", "portfolio", "data"],
      "properties": {
        "research_first": { "type": "string", "enum": ["pass", "warn", "block", "missing"] },
        "risk_boundary": { "type": "string", "enum": ["pass", "warn", "block", "missing"] },
        "macro": { "type": "string", "enum": ["pass", "warn", "block", "missing"] },
        "portfolio": { "type": "string", "enum": ["pass", "warn", "block", "missing"] },
        "data": { "type": "string", "enum": ["pass", "warn", "block", "missing"] }
      }
    },
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["why", "confidence_drivers", "blocked_reasons"],
      "properties": {
        "why": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["stage", "source_id", "finding"],
            "properties": {
              "stage": { "type": "string" },
              "source_id": { "type": ["string", "null"] },
              "finding": { "type": "string" }
            }
          },
          "minItems": 1
        },
        "confidence_drivers": { "type": "array", "items": { "type": "string" } },
        "blocked_reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "invalidation_conditions": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "source_ids": {
      "type": "object",
      "additionalProperties": false,
      "required": ["market_snapshot_id", "research_snapshot_ids", "decision_id", "portfolio_id", "risk_state_id", "macro_state_id"],
      "properties": {
        "market_snapshot_id": { "type": ["string", "null"] },
        "research_snapshot_ids": { "type": "array", "items": { "type": "string" } },
        "decision_id": { "type": ["string", "null"] },
        "portfolio_id": { "type": ["string", "null"] },
        "risk_state_id": { "type": ["string", "null"] },
        "macro_state_id": { "type": ["string", "null"] }
      }
    }
  }
}
