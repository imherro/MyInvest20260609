{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "target_pool_id",
    "basis_date",
    "generated_at",
    "source",
    "status",
    "entries"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "target_pool_id": { "type": "string", "minLength": 1 },
    "basis_date": { "type": "string", "format": "date" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "enum": ["decision", "system", "seed", "qmt_mock"] },
    "status": { "type": "string", "enum": ["active", "blocked"] },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pool_type", "symbols"],
        "properties": {
          "pool_type": { "type": "string", "enum": ["approved", "research_first", "blocked"] },
          "symbols": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}

