{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "as_of",
    "generated_at",
    "source_ids",
    "models",
    "consensus_score",
    "consensus_state",
    "disagreement_score",
    "calibrated_confidence",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "status": { "type": "string", "enum": ["ok", "empty"] },
    "as_of": { "type": ["string", "null"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_ids": {
      "type": "object",
      "additionalProperties": false,
      "required": ["market_snapshot_id", "portfolio_id", "research_snapshot_ids"],
      "properties": {
        "market_snapshot_id": { "type": ["string", "null"] },
        "portfolio_id": { "type": ["string", "null"] },
        "research_snapshot_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["model_id", "score", "stance", "confidence", "evidence"],
        "properties": {
          "model_id": { "type": "string", "minLength": 1 },
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "stance": { "type": "string", "enum": ["risk_on", "neutral", "risk_off"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "consensus_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "consensus_state": { "type": "string", "enum": ["risk_on", "neutral", "risk_off"] },
    "disagreement_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "calibrated_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
