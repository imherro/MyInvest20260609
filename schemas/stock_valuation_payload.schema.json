{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "symbol",
    "valuation_state",
    "research_first_status",
    "risk_score",
    "signal_type",
    "gates",
    "reason"
  ],
  "properties": {
    "symbol": { "type": "string", "minLength": 1 },
    "valuation_state": {
      "type": "string",
      "enum": ["pass", "fail", "blocked", "missing"]
    },
    "research_first_status": {
      "type": "string",
      "enum": ["PASSED", "BLOCKED"]
    },
    "risk_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "signal_type": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["liquidity", "valuation", "momentum", "structural", "risk_event"]
      },
      "minItems": 1
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "valuation", "liquidity"],
      "properties": {
        "profile": { "type": "string", "enum": ["pass", "fail", "blocked", "missing"] },
        "valuation": { "type": "string", "enum": ["pass", "fail", "blocked", "missing"] },
        "liquidity": { "type": "string", "enum": ["pass", "fail", "blocked", "missing"] }
      }
    },
    "reason": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
  }
}
