{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "symbol",
    "valuation_score",
    "fair_value_range",
    "deviation",
    "risk_flag",
    "confidence",
    "method",
    "price",
    "rating"
  ],
  "properties": {
    "symbol": { "type": "string", "minLength": 1 },
    "valuation_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "fair_value_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["low", "mid", "high"],
      "properties": {
        "low": { "type": "number", "minimum": 0 },
        "mid": { "type": "number", "minimum": 0 },
        "high": { "type": "number", "minimum": 0 }
      }
    },
    "deviation": { "type": "number", "minimum": -10, "maximum": 10 },
    "risk_flag": { "type": "string", "enum": ["low", "medium", "high"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "method": { "type": "string", "minLength": 1 },
    "price": { "type": "number", "minimum": 0 },
    "rating": { "type": "string", "enum": ["Undervalued", "Fair", "Overvalued", "Watch"] }
  }
}

